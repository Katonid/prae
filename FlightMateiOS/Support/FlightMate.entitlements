<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- iCloud-Key-Value-Store: synchronisiert Spots und Drohnenmodell
	     zwischen den Geräten des Nutzers. Die API-Schlüssel gehen
	     separat über den iCloud-Schlüsselbund (kSecAttrSynchronizable,
	     braucht keine Entitlements). -->
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>
	<!-- CloudKit: synchronisiert den Medien-Katalog des Archivs
	     (Drone Media Explorer, SwiftData + CloudKit — nur Metadaten,
	     keine Medien-Dateien). Container legt Xcode beim ersten
	     signierten Build automatisch an. -->
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
		<string>CloudDocuments</string>
	</array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.de.familie.flightmate</string>
	</array>
	<!-- iCloud Drive (CloudDocuments): spiegelt die verkleinerten
	     Logbuch-Fotos auf alle Geräte — das KVS-Limit (1 MB) gilt
	     nur für die Eintrags-Daten, nicht für iCloud Drive. -->
	<key>com.apple.developer.ubiquity-container-identifiers</key>
	<array>
		<string>iCloud.de.familie.flightmate</string>
	</array>
</dict>
</plist>
